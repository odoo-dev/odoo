<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mail.Switcher" owl="1">
        <div class="o_Switcher" t-att-class="{is_open: state.isOpen }">
            <div class="o_Switcher_overlay" t-on-click="_close"></div>
            <div class="o_Switcher_box">
                <form>
                    <SuggestionsList
                        suggestionManagerLocalId="composer.suggestionManager.localId"
                        isBelow="true"
                        t-on-suggestion-selected="_onSuggestionSelected"
                    >
                        <input type="text" name="switch" t-ref="inputSwitcher"/>
                    </SuggestionsList>
                </form>
            </div>
        </div>
    </t>

</templates>
