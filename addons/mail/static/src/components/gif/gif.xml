<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mail.Gif" owl="1">
        <div class="o_Gif">
            <div>
                <input type="text" t-on-keydown="_onKeydown" />
            </div>

            <GifList gifManagerLocalId="props.gifManagerLocalId" />

            <div class="grid">
                <div class="grid-item" t-foreach="gifManager.categories" t-as="category">
                    <img class="gif" t-att-src="category.image" t-on-load="_update" />
                    <span class="gif-title">
                        <t t-esc="category.searchterm"/>
                    </span>
                </div>
            </div>
        </div>
    </t>

</templates>
