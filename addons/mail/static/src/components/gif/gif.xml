<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mail.Gif" owl="1">
        <div class="o_Gif">
            <div>
                <input type="text" t-on-keydown="_onKeydown" />
            </div>
            <div class="grid" t-if="!gifManager.search.length">
                <t t-foreach="gifManager.categories" t-as="category" t-key="category.id">
                    <div class="grid-item">
                        <img class="gif" t-att-src="category.image" t-on-load="_update" />
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
