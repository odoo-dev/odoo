<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mail.VideoRoom" owl="1">
        <div class="o_VideoRoom">
            <div class="o_VideoRoom_video_container">
                <t t-if="activePeers and activePeers.length">
                    <t t-foreach="activePeers" t-as="peer" t-key="peer.token">
                        <div class="o_VideoRoom_video_box" t-key="'video_box_'+peer.token">
                            <video class="o_VideoRoom_video" t-key="'video_'+peer.token" t-att-muted="localToken === peer.token" t-att-token="peer.token" t-ref="video_{{ peer.token }}" t-on-loadedmetadata="_onVideoLoadedMetaData"/>
                            <span class="o_VideoRoom_video_name" t-esc="peer.token"/>
                        </div>
                    </t>
                </t>
            </div>
        </div>
    </t>

</templates>