<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mail.SuggestionsList" owl="1">
        <div t-on-keyup="_onKeyup">
            <t t-slot="default" />
            <t t-if="suggestionManager.hasSuggestions">
                <div class="o_SuggestionsList" t-att-class="{ 'o-lowPosition': props.isBelow }">
                    <div class="o_SuggestionsList_drop" t-att-class="{ 'dropdown': props.isBelow, 'dropup': !props.isBelow }">
                        <div class="o_SuggestionsList_list dropdown-menu show">
                            <t t-foreach="suggestionManager.mainSuggestedRecordsList" t-as="record" t-key="record.localId">
                                <Suggestion
                                    suggestionManagerLocalId="suggestionManager.localId"
                                    isActive="record === suggestionManager.activeSuggestedRecord"
                                    modelName="suggestionManager.suggestionModelName"
                                    recordLocalId="record.localId"
                                />
                            </t>
                            <t t-if="suggestionManager.mainSuggestedRecordsList.length > 0 and suggestionManager.extraSuggestedRecordsList.length > 0">
                                <div role="separator" class="dropdown-divider"/>
                            </t>
                            <t t-foreach="suggestionManager.extraSuggestedRecordsList" t-as="record" t-key="record.localId">
                                <Suggestion
                                suggestionManagerLocalId="suggestionManager.localId"
                                isActive="record === suggestionManager.activeSuggestedRecord"
                                modelName="suggestionManager.suggestionModelName"
                                recordLocalId="record.localId"
                            />
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </div>
</t>

</templates>
