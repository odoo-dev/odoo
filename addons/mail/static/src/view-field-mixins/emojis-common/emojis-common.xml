<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <div t-name="mail.viewFieldMixins.emojisCommon.dropdown" class="o_mail_emojis_dropdown o_mail_add_emoji dropdown position-relative">
        <button class="btn btn-block dropdown-toggle px-3 py-1"
            type="button"
            data-toggle="dropdown"
            aria-haspopup="true"
            aria-expanded="false"
            title="Add an emoji">
            <i class="fa fa-smile-o"/>
        </button>
        <div class="dropdown-menu dropdown-menu-right border-0 p-2" style="width: 406px">
            <t t-call="mail.viewFieldMixins.emojisCommon.dropdownEmojis">
                <t t-set="emojis" t-value="widget.emojis"></t>
            </t>
        </div>
    </div>

    <div t-name="mail.viewFieldMixins.emojisCommon.dropdownEmojis" class="o_mail_emoji_container">
        <t t-foreach="emojis" t-as="emoji">
            <span t-att-data-emoji="emoji.sources[0]" class="o_mail_emoji" t-att-title="emoji.description" t-att-aria-label="emoji.description">
                <t t-raw="emoji.unicode"/>
            </span>
        </t>
    </div>

</templates>
