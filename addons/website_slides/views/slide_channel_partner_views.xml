<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="slide_channel_partner_view_search" model="ir.ui.view">
            <field name="name">slide.channel.partner.search</field>
            <field name="model">slide.channel.partner</field>
            <field name="arch" type="xml">
                <search string="Channel Member">
                    <field name="partner_id"/>
                    <field name="partner_email"/>
                    <field name="channel_id"/>
                    <separator/>
                    <filter name="completed" string="Completed" domain="[('completed', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="slide_channel_partner_view_tree" model="ir.ui.view">
            <field name="name">slide.channel.partner.tree</field>
            <field name="model">slide.channel.partner</field>
            <field name="arch" type="xml">
                <tree string="Attendees" editable="top">
                    <field name="create_date" string="Enrolled On"/>
                    <field name="write_date" string="Last Action On"/>
                    <field name="partner_id" string="Contact"/>
                    <field name="partner_email"/>
                    <field name="channel_id" string="Channel" invisible="context.get('default_channel_id',False)" />
                    <field name="completion" string="Progress" widget="progressbar" />
                    <button name="unlink" title="Remove" icon="fa-times" type="object"/>
                </tree>
            </field>
        </record>

        <!-- Courses of partner (Stat button on Contact's form view) -->
        <record id="slide_channel_partner_view_tree_contact" model="ir.ui.view">
            <field name="name">slide.channel.partner.view.tree.contact</field>
            <field name="model">slide.channel.partner</field>
            <field name="priority" eval="32"/>
            <field name="arch" type="xml">
                <tree string="Followed Courses" editable="top">
                    <field name="channel_id" string="Course Name"/>
                    <field name="user_id"/>
                    <field name="create_date" string="Enrolled On"/>
                    <field name="write_date" string="Last Action On"/>
                    <field name="completion" string="Progress" widget="progressbar"/>
                    <field name="channel_type" optional="hide"/>
                    <field name="visibility" optional="hide"/>
                    <field name="enroll" widget="badge" decoration-success="enroll == 'public'"
                           decoration-info="enroll == 'invite'" decoration-warning="enroll == 'payment'"
                           optional="hide"/>
                    <field name="website_id" groups="website.group_multi_website" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="slide_channel_partner_action" model="ir.actions.act_window">
            <field name="name">Attendees</field>
            <field name="res_model">slide.channel.partner</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="slide_channel_partner_view_tree"/>
            <field name="search_view_id" ref="website_slides.slide_channel_partner_view_search"/>
        </record>

        <record id="slide_channel_partner_view_kanban" model="ir.ui.view">
            <field name="name">slide.channel.partner.view.kanban</field>
            <field name="model">slide.channel.partner</field>
            <field name="arch" type="xml">
                <kanban string="Followed Courses">
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click oe_kanban_card">
                                <div class="o_kanban_card_header">
                                    <div class="o_kanban_card_header_title mb-3">
                                        <strong class="o_kanban_record_title oe_partner_heading">
                                            <field name="channel_id"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="completion" widget="progressbar"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="slide_channel_partner_view_form" model="ir.ui.view">
            <field name="name">slide.channel.partner.view.form</field>
            <field name="model">slide.channel.partner</field>
            <field name="arch" type="xml">
                <form string="Followed Courses Details">
                    <sheet>
                        <div class="oe_title">
                            <label for="channel_id" class="oe_edit_only"/>
                            <h1><field name="channel_id" class="oe_inline"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="create_date" string="Enrolled On"/>
                                <field name="write_date" string="Last Action On"/>
                                <field name="completion" string="Progress" widget="progressbar"/>
                            </group>
                            <group>
                                <field name="partner_id" string="Attendee Name"/>
                                <field name="user_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="slide_channel_partner_action_contact_overview" model="ir.actions.act_window">
            <field name="name">Followed Courses</field>
            <field name="res_model">slide.channel.partner</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="view_id" ref="slide_channel_partner_view_tree_contact"/>
        </record>

        <!-- Attendees Report -->
        <record id="slide_channel_partner_view_tree_report" model="ir.ui.view">
            <field name="name">slide.channel.partner.view.tree.report</field>
            <field name="model">slide.channel.partner</field>
            <field name="arch" type="xml">
                <tree string="Attendees" create="0" editable="top">
                    <field name="create_date" string="Enrolled On"/>
                    <field name="partner_id" string="Attendee Name"/>
                    <field name="partner_email"/>
                    <field name="channel_id" string="Course Name"/>
                    <field name="user_id"/>
                    <field name="write_date" string="Last Action On"/>
                    <field name="completion" string="Progress" widget="progressbar"/>
                </tree>
            </field>
        </record>

        <record id="slide_channel_partner_action_report" model="ir.actions.act_window">
            <field name="name">Attendees</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">slide.channel.partner</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="slide_channel_partner_view_tree_report"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No attendees yet.
                </p>
            </field>
        </record>
    </data>
</odoo>
