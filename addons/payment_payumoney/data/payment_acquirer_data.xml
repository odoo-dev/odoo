<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="account_payment_method_payu" model="account.payment.method">
            <field name="name">PayUmoney</field>
            <field name="method_type" ref="payment.account_payment_method_type_electronic_in"/>
            <field name="state">deactivated</field>
        </record>
        <record id="payment.payment_acquirer_payu" model="payment.acquirer">
            <field name="name">PayUmoney</field>
            <field name="image_128" type="base64" file="payment_payumoney/static/src/img/payumoney_icon.png"/>
            <field name="provider">payumoney</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="view_template_id" ref="payumoney_form"/>
            <field name="inbound_payment_method_id" ref="account_payment_method_payu"/>
        </record>
    </data>
</odoo>
