<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="redirect_template">
         <form t-att-action="tx_url" method="post">
            <input type="hidden" name="ACCOUNT.PSPID" t-att-value="ACCOUNT.PSPID"/>
             <input type="hidden" name="ALIAS.ORDERID" t-att-value="ALIAS.ORDERID"/>
             <input type="hidden" name="ALIAS.ALIASID" t-att-value="ALIAS.ALIASID"/>
            <!-- arj fixme: use it with the save my payment details checkbox. need to update the value according to
            what the user check... so redirect + JS ? -->
<!--             <input type="hidden" name="ALIAS.STOREPERMANENTLY" t-att-value="store"/>-->
             <input type="hidden" name="LAYOUT.LANGUAGE" t-att-value="LAYOUT.LANGUAGE"/>
             <input type="hidden" name="CARD.PAYMENTMETHOD" t-att-value="CARD.PAYMENTMETHOD"/>
             <input type="hidden" name="PARAMETERS.ACCEPTURL" t-att-value="PARAMETERS.ACCEPTURL"/>
             <input type="hidden" name="PARAMETERS.EXCEPTIONURL" t-att-value="PARAMETERS.EXCEPTIONURL"/>
             <input type="hidden" name="PARAMPLUS" t-att-value="PARAMPLUS"/>
        </form>
    </template>


    <template id="inline_form">
        <div t-attf-id="ogone_iframe_container_{{acquirer_id}}">
            <iframe t-attf-id="oe_ogone_iframe_{{id}}"
                    t-attf-name="oe_ogone_iframe_{{id}}"
                    class="oe_ogone_iframe"/>
        </div>
    </template>

    <template id="feedback" name="Payment processing page">
        <t t-call="web.layout">
            <t t-set="head">
                <t t-call-assets="web.assets_common"/>
                <t t-call-assets="web.assets_frontend"/>
                <script type="text/javascript"
                        src="/payment_ogone/static/src/js/payment_feedback.js"/>
                <link rel="stylesheet"
                      type="text/scss"
                      href="/payment_ogone/static/src/scss/payment_form.scss"/>
            </t>
            <!--  Small spinner running in an iframe  -->
            <div class="p-5 o_payment_feedback" id="payment_feedback">
                <div class="row">
                    <div class="mx-auto align-self-center o_ogone_spinner">
                        <i class="fa fa-spinner fa-pulse fa-5x"/>
                        <!-- The content here is handled by JS -->
                    </div>
                    <div class="o_ogone_error_message">
                        <div class="ogone_error">
                            The payment could not be processed. See the following error
                            from the payment provider for more information.
                        </div>
                        <div class="o_ogone_error_name"/>
                        <div class="o_btn_back">
                            <a role="button"
                               id="btn_payment_status"
                               class="btn btn-link btn-primary">
                                Go back
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
