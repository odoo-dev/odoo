<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Templates for Dynamic Snippet -->
        <template id="dynamic_filter_template_add_product_to_cart" name="Add Product to Cart">
            <t t-foreach="records" t-as="record">
                <div class="o_carousel_product_card card h-100">
                    <div t-if="is_sample" class="h5 o_ribbon_right bg-primary text-uppercase">Sample</div>
                    <input type="hidden" name="product-id" t-att-data-product-id="record.get('id')"/>
                    <a class="o_carousel_product_img_link" t-att-href="record.get('call_to_action_url')">
                        <img class="o_carousel_product_card_img_top card-img-top" loading="lazy" t-att-src="record.get('image_512')"
                            t-att-alt="record.get('display_name')"/>
                    </a>
                    <i t-if="record.get('product_selection') == 'latest_viewed'" class="fa fa-trash o_carousel_product_remove js_remove"></i>
                    <div class="o_carousel_product_card_body card-body border-top">
                        <a t-att-href="record.get('call_to_action_url')" class="text-decoration-none">
                            <div class="h6 card-title mb-0 text-truncate" t-raw="record.get('display_name')"/>
                        </a>
                        <t t-raw="record.get('rating')"/>
                    </div>
                    <div class="o_carousel_product_card_footer card-footer d-flex align-items-center">
                        <div class="d-block font-weight-bold" t-raw="record.get('price')"/>
                        <button t-if="'id' in record" type="button" role="button" class="btn btn-primary js_add_cart ml-auto" title="Add to Cart">
                            <i class="fa fa-fw fa-shopping-cart"/>
                        </button>
                    </div>
                </div>
            </t>
        </template>

        <template id="dynamic_filter_template_view_product_detail" name="Detailed Product">
            <t t-foreach="records" t-as="record">
                <div class="o_carousel_product_card card h-100" t-att-data-url="record.get('call_to_action_url')">
                    <div t-if="is_sample" class="h5 o_ribbon_right bg-primary text-uppercase">Sample</div>
                    <a class="o_carousel_product_img_link" t-att-href="record.get('call_to_action_url')">
                        <img class="card-img-top p-3" loading="lazy" t-att-src="record.get('image_512')" t-att-alt="record.get('display_name')"/>
                    </a>
                    <div class="o_carousel_product_card_body card-body">
                        <div class="card-title h5" t-raw="record.get('display_name')"/>
                        <div t-if="'description_sale' in record" class="card-text" t-raw="record.get('description_sale')"/>
                        <t t-raw="record.get('rating')"/>
                    </div>
                    <div class="o_carousel_product_card_footer card-footer d-flex align-items-center">
                        <div class="card-text text-center" t-raw="record.get('price')"/>
                        <a class="btn btn-primary ml-auto" t-att-href="record.get('call_to_action_url')">
                            <i class="fa fa-fw fa-eye"/>
                        </a>
                    </div>
                </div>
            </t>
        </template>

        <template id="dynamic_filter_template_mini_product_image" name="Image only">
            <t t-foreach="records" t-as="record">
                <div class="card h-100" t-att-data-url="record.get('call_to_action_url')">
                    <div t-if="is_sample" class="h5 o_ribbon_right bg-primary text-uppercase">Sample</div>
                    <a class="o_carousel_product_img_link" t-att-href="record.get('call_to_action_url')">
                        <img class="card-img-top p-3" loading="lazy" t-att-src="record.get('image_512')" t-att-alt="record.get('display_name')"/>
                    </a>
                </div>
            </t>
        </template>

        <template id="dynamic_filter_template_mini_product_price" name="Image with price">
            <t t-foreach="records" t-as="record">
                <div class="card h-100" t-att-data-url="record.get('call_to_action_url')">
                    <div t-if="is_sample" class="h5 o_ribbon_right bg-primary text-uppercase">Sample</div>
                    <a class="o_carousel_product_img_link" t-att-href="record.get('call_to_action_url')">
                        <img class="card-img-top p-3" loading="lazy" t-att-src="record.get('image_512')" t-att-alt="record.get('display_name')"/>
                    </a>
                    <div class="card-text text-center" t-raw="record.get('price')"/>
                </div>
            </t>
        </template>

        <template id="dynamic_filter_template_mini_product_name" name="Image with name">
            <t t-foreach="records" t-as="record">
                <div class="card h-100" t-att-data-url="record.get('call_to_action_url')">
                    <div t-if="is_sample" class="h5 o_ribbon_right bg-primary text-uppercase">Sample</div>
                    <a class="o_carousel_product_img_link" t-att-href="record.get('call_to_action_url')">
                        <img class="card-img-top p-3" loading="lazy" t-att-src="record.get('image_512')" t-att-alt="record.get('display_name')"/>
                    </a>
                    <div class="h6 card-title mb-1 px-1 text-center text-truncate" t-raw="record.get('display_name')"/>
                </div>
            </t>
        </template>
    </data>
</odoo>
