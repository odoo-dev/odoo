<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="point_of_sale.PosDialog" t-inherit="web.Dialog" t-inherit-mode="primary">
        <xpath expr="//t[@t-slot='header']/t" position="replace">
            <t t-call="point_of_sale.PosDialog.header">
                <t t-set="hideCloseButton" t-value="props.hideCloseButton"/>
                <t t-set="fullscreen" t-value="isFullscreen"/>
            </t>
        </xpath>
    </t>

    <t t-name="point_of_sale.PosDialog.header" t-inherit="web.Dialog.header" t-inherit-mode="primary">
        <xpath expr="//t[@t-if='!fullscreen']" position="attributes">
            <attribute name="t-if">!fullscreen and !hideCloseButton</attribute>
        </xpath>
    </t>

</templates>
