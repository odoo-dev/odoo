<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.DiscussSidebar" t-inherit-mode="extension">
        <xpath expr="//Category[contains(@class, 'o_DiscussSidebar_groupChat')]" position="before">
            <t t-set="livechats" t-value="livechatsList()"/>
            <Category class="o_DiscussSidebar_group o_DiscussSidebar_groupLivechat" categoryLocalId="discuss.categoryLivechat.localId">
                <t t-set-slot="title">
                    <CategoryLivechatTitle />
                </t>
                <t t-set-slot="activeThread">
                    <t t-if="currentThread and currentThread.channel_type === 'livechat'">
                        <CategoryLivechatItem threadLocalId="currentThread.localId"/>
                    </t>
                </t>
                <t t-set-slot="content">
                    <t t-foreach="livechats" t-as="livechat" t-key="livechat.localId">
                        <CategoryLivechatItem threadLocalId="livechat.localId" />
                    </t>
                </t>
            </Category>
        </xpath>
    </t>
</templates>
