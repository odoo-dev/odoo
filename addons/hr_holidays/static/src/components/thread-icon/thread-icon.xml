<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.ThreadIcon" t-inherit-mode="extension">
        <xpath expr="//*[@name='noImStatusCondition']" position="before">
            <t t-elif="thread.$$$correspondent(mself).$$$imStatus(mself) === 'leave_online'">
                <div class="o-ThreadIcon-online fa fa-plane" title="Online"/>
            </t>
            <t t-elif="thread.$$$correspondent(mself).$$$imStatus(mself) === 'leave_away'">
                <div class="o-ThreadIcon-away fa fa-plane" title="Away"/>
            </t>
            <t t-elif="thread.$$$correspondent(mself).$$$imStatus(mself) === 'leave_offline'">
                <div class="o-ThreadIcon-offline fa fa-plane" title="Out of office"/>
            </t>
        </xpath>
    </t>
</templates>
