<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="assets_backend" inherit_id="web.assets_backend">
    <xpath expr="script[last()]" position="after">
      <script type="text/javascript" src="/hr_holidays/static/src/js/time_off_calendar.js"/>
      <script type="text/javascript" src="/hr_holidays/static/src/js/leave_stats_widget.js"/>
      <script type="text/javascript" src="/hr_holidays/static/src/bugfix/bugfix.js"/>
      <script type="text/javascript" src="/hr_holidays/static/src/features/hr_holidays/hr_holidays.js"/>
      <script type="text/javascript" src="/hr_holidays/static/src/model-addons/partner/partner.js"/>
    </xpath>
    <xpath expr="link[last()]" position="after">
      <link rel="stylesheet" type="text/scss" href="/hr_holidays/static/src/scss/time_off.scss"/>
      <link rel="stylesheet" type="text/scss" href="/hr_holidays/static/src/bugfix/bugfix.scss"/>
      <link rel="stylesheet" type="text/scss" href="/hr_holidays/static/src/components/thread-view/thread-view.scss"/>
    </xpath>
  </template>
  <template id="tests_assets" name="hr_holidays_tests_assets" inherit_id="web.tests_assets">
    <xpath expr="." position="inside">
      <script type="text/javascript" src="/hr_holidays/static/src/mock-models.js"/>
      <script type="text/javascript" src="/hr_holidays/static/src/mock-server.js"/>
    </xpath>
  </template>
  <template id="qunit_suite" name="hr_holidays_qunit_suite" inherit_id="web.qunit_suite_tests">
      <xpath expr="." position="inside">
          <script type="text/javascript" src="/hr_holidays/static/src/bugfix/bugfix_tests.js"/>
          <script type="text/javascript" src="/hr_holidays/static/src/components/partner-im-status-icon/partner-im-status-icon_tests.js"/>
          <script type="text/javascript" src="/hr_holidays/static/src/components/thread-icon/thread-icon_tests.js"/>
          <script type="text/javascript" src="/hr_holidays/static/src/components/thread-view/thread-view_tests.js"/>
          <script type="text/javascript" src="/hr_holidays/static/tests/test_leave_stats_widget.js"/>
      </xpath>
  </template>
</odoo>
