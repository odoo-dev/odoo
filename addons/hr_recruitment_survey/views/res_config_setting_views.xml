<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr.recruitment.survey</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_recruitment.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <div id="interview_forms" position="replace">
                <div class="content-group">
                    <div class="mt8">
                        <button name="%(survey.action_survey_form)d" icon="fa-arrow-right" type="action" string="Interview Survey" class="btn-link"/>
                    </div>
                </div>
                <separator/>
                    <span class="o_form_label">Interview Templates</span>
                    <span class="fa fa-lg fa-building-o" title="Values set here are job-specific." role="img" aria-label="Values set here are job-specific."/>
                    <div class="text-muted">
                         Configure General Interview Template  <br />
                         to help recruiter during the recruitment process
                    </div>
                    <div>
                        <field name="interview_template" class="w-100" nolabel="1"/>
                    </div>
                <div class="content-group">
                     <div class="text-muted">
                        Or Configure Interview Template by Job
                     </div>
                     <button name="%(hr.action_hr_job)d" icon="fa-arrow-right" type="action" string="Jobs Configuration" class="btn-link"/>
                </div>
            </div>
        </field>
    </record>
</odoo> 
