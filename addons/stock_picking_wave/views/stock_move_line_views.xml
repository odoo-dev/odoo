<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_move_line_view_search_inherited" model="ir.ui.view">
        <field name="name">stock.move.line.search.wave</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.stock_move_line_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='by_date']" position="after">
                <filter string="Transfers" name="by_picking" domain="[]" context="{'group_by': 'picking_id'}"/>
                <filter string="Location" name="by_location" domain="[]" context="{'group_by': 'location_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_inherited" model="ir.ui.view">
        <field name="name">stock.move.line.tree.wave</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="before">
                <field name="wave_id" invisible="1"/>
                <button name="action_open_wave" title="Open wave picking" type="object" icon="fa-filter" attrs="{'invisible': [('wave_id', '=', False)]}"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_detailed_inherited" model="ir.ui.view">
        <field name="name">stock.move.line.detailed.wave</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='qty_done']" position="after">
                <field name="wave_id" invisible="1"/>
                <button name="action_open_wave" title="Open wave picking" type="object" icon="fa-filter" attrs="{'invisible': [('wave_id', '=', False)]}"/>
            </xpath>
            <xpath expr="//field[@name='lot_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_stock_move_operations_to_wave" model="ir.ui.view">
        <field name="name">stock_picking_wave.move.line.tree</field>
        <field name="model">stock.move.line</field>
        <field name="arch" type="xml">
            <tree export_xlsx="0" create="0" import="0" default_order="location_id">
                <header>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                    <button name="add_to_wave" type="object" string="Add operations"/>
                </header>
                <field name="state" invisible="1"/>
                <field name="product_id"/>
                <field name="picking_id"/>
                <field name="lot_id" groups="stock.group_production_lot" optional="hide"/>
                <field name="location_id"/>
                <field name="scheduled_date"/>
                <field name="company_id" invisible="1"/>
                <field name="location_dest_id"/>
                <field name="package_id" groups="stock.group_tracking_lot"/>
                <field name="result_package_id" groups="stock.group_tracking_lot" optional="hide"/>
                <field name="product_uom_qty"/>
                <field name="product_uom_id"/>
                <field name="qty_done"/>
                <field name="wave_id" invisible="1"/>
                <button name="action_open_wave" title="Open wave picking" type="object" icon="fa-filter" attrs="{'invisible': [('wave_id', '=', False)]}"/>
            </tree>
        </field>
    </record>

    <record id="view_move_line_tree" model="ir.ui.view">
        <field name="name">stock_picking_wave.move.line.tree</field>
        <field name="model">stock.move.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="product_id"/>
                <field name="product_uom_category_id" invisible="1"/>
                <field name="lot_id" groups="stock.group_production_lot"/>
                <field name="location_id"/>
                <field name="company_id" invisible="1"/>
                <field name="location_dest_id"/>
                <field name="package_id" groups="stock.group_tracking_lot"/>
                <field name="result_package_id" groups="stock.group_tracking_lot"/>
                <field name="product_uom_qty"/>
                <field name="product_uom_id"/>
                <field name="qty_done"/>
                <field name="wave_id" invisible="1"/>
                <button name="action_open_wave" title="Open wave picking" type="object" icon="fa-filter" attrs="{'invisible': [('wave_id', '=', False)]}"/>
            </tree>
        </field>
    </record>
</odoo>
