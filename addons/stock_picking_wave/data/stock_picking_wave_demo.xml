<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <!-- Add wave picking -->
    <record id="stock_picking_wave_1" model="stock.picking.wave">
        <field name="picking_type_id" ref="stock.picking_type_out"/>
        <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="stock_picking_wave_2" model="stock.picking.wave">
        <field name="picking_type_id" ref="stock.picking_type_out"/>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <!-- Resource: stock.inventory -->
    <record id="stock_inventory_wave" model="stock.inventory">
        <field name="name">Starting Inventory</field>
    </record>

    <!-- Resource: stock.inventory.line -->
    <record id="stock_inventory_line_0" model="stock.inventory.line">
        <field name="product_id" ref="product.consu_delivery_01"/>
        <field name="product_uom_id" ref="uom.product_uom_unit"/>
        <field name="inventory_id" ref="stock_picking_wave.stock_inventory_wave"/>
        <field name="product_qty">7</field>
        <field name="location_id" ref="stock.stock_location_14"/>
    </record>

    <record id="stock_inventory_line_1" model="stock.inventory.line">
        <field name="product_id" ref="product.consu_delivery_02"/>
        <field name="product_uom_id" ref="uom.product_uom_unit"/>
        <field name="inventory_id" ref="stock_picking_wave.stock_inventory_wave"/>
        <field name="product_qty">5</field>
        <field name="location_id" ref="stock.stock_location_components"/>
    </record>

    <record id="stock_inventory_line_2" model="stock.inventory.line">
        <field name="product_id" ref="product.consu_delivery_02"/>
        <field name="product_uom_id" ref="uom.product_uom_unit"/>
        <field name="inventory_id" ref="stock_picking_wave.stock_inventory_wave"/>
        <field name="product_qty">15</field>
        <field name="location_id" ref="stock.stock_location_14"/>
    </record>

    <record id="stock_inventory_line_3" model="stock.inventory.line">
        <field name="product_id" ref="product.consu_delivery_01"/>
        <field name="product_uom_id" ref="uom.product_uom_unit"/>
        <field name="inventory_id" ref="stock_picking_wave.stock_inventory_wave"/>
        <field name="product_qty">13</field>
        <field name="location_id" ref="stock.stock_location_components"/>
    </record>

    <!-- Inventory start -->
    <function model="stock.inventory" name="_action_start">
        <function eval="[[('state','=','draft'),('id', '=', ref('stock_inventory_wave'))]]" model="stock.inventory" name="search"/>
    </function>
    <!-- Inventory validate -->
    <function model="stock.inventory" name="action_validate">
        <function eval="[[('state','=','confirm'),('id', '=', ref('stock_inventory_wave'))]]" model="stock.inventory" name="search"/>
    </function>

    <!-- Add picking -->
    <record id="Picking_A" model="stock.picking">
        <field name="move_type">one</field>
        <field name="priority">1</field>
        <field name="user_id" eval="False"/>
        <field name="picking_type_id" ref="stock.picking_type_out"/>
        <field name="location_id" ref="stock.stock_location_stock"/>
        <field name="location_dest_id" ref="stock.stock_location_customers"/>
        <field name="company_id" ref="base.main_company"/>
    </record>
    <!-- Add stock move -->
    <record id="stock_move1" model="stock.move">
        <field name="name">A first stock move</field>
        <field name="picking_type_id" ref="stock.picking_type_out"/>
        <field name="picking_id" ref="Picking_A"/>
        <field name="location_id" ref="stock.stock_location_stock"/>
        <field name="location_dest_id" ref="stock.stock_location_customers"/>
        <field name="product_uom_qty">20</field>
        <field name="product_uom" ref="uom.product_uom_unit" />
        <field name="product_id" ref="product.consu_delivery_01"/>
    </record>
    <record id="stock_move2" model="stock.move">
        <field name="name">A second stock move</field>
        <field name="picking_type_id" ref="stock.picking_type_out"/>
        <field name="picking_id" ref="Picking_A"/>
        <field name="location_id" ref="stock.stock_location_stock"/>
        <field name="location_dest_id" ref="stock.stock_location_customers"/>
        <field name="product_uom_qty">20</field>
        <field name="product_uom" ref="uom.product_uom_unit" />
        <field name="product_id" ref="product.consu_delivery_02"/>
    </record>
    <!-- Confirm Wave Pickings -->
    <function model="stock.move" name="_action_confirm">
        <value eval="ref('stock_move1')"/>
    </function>
    <function model="stock.move" name="_action_confirm">
        <value eval="ref('stock_move2')"/>
    </function>
    <function model="stock.move" name="_action_assign">
        <value eval="ref('stock_move1')"/>
    </function>
    <function model="stock.move" name="_action_assign">
        <value eval="ref('stock_move2')"/>
    </function>
    <function model="stock.move.line" name="write">
        <value model="stock.move.line" search="[('move_id', '=', ref('stock_picking_wave.stock_move1')), ('location_id', '=', ref('stock.stock_location_14'))]"/>
        <value eval="{'wave_id': ref('stock_picking_wave_1')}"/>
    </function>
    <function model="stock.move.line" name="write">
        <value model="stock.move.line" search="[('move_id', '=', ref('stock_picking_wave.stock_move2')), ('location_id', '=', ref('stock.stock_location_14'))]"/>
        <value eval="{'wave_id': ref('stock_picking_wave_1')}"/>
    </function>
    <function model="stock.move.line" name="write">
        <value model="stock.move.line" search="[('move_id', '=', ref('stock_picking_wave.stock_move1')), ('location_id', '=', ref('stock.stock_location_components'))]"/>
        <value eval="{'wave_id': ref('stock_picking_wave_2')}"/>
    </function>
    <function model="stock.move.line" name="write">
        <value model="stock.move.line" search="[('move_id', '=', ref('stock_picking_wave.stock_move2')), ('location_id', '=', ref('stock.stock_location_components'))]"/>
        <value eval="{'wave_id': ref('stock_picking_wave_2')}"/>
    </function>
    <function model="stock.move.line" name="write">
        <value model="stock.move.line" search="[('move_id', 'in', (ref('stock_picking_wave.stock_move1'), ref('stock_picking_wave.stock_move2'))), ('location_id', '=', ref('stock.stock_location_components'))]"/>
        <value eval="{'wave_id': ref('stock_picking_wave_2')}"/>
    </function>
    <!-- Check Availability -->
</data></odoo>
