<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- New report paperformat for din5008 format -->
        <record id="paperformat_euro_din_a" model="report.paperformat">
            <field name="name">European A4 for DIN5008 Type A</field>
            <field name="default" eval="False" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">27</field>
            <field name="margin_bottom">40</field>
            <field name="margin_left">20</field>
            <field name="margin_right">10</field>
            <field name="dpi">70</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">27</field>
        </record>

        <record id="paperformat_euro_din" model="report.paperformat">
            <field name="name">European A4 for DIN5008 Type B</field>
            <field name="default" eval="False" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">45</field>
            <field name="margin_bottom">40</field>
            <field name="margin_left">20</field>
            <field name="margin_right">10</field>
            <field name="dpi">70</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">45</field>
        </record>

        <template id="assets_common" name="l10n_de_din5008_report" inherit_id="web.report_assets_common">
            <xpath expr="." position="inside">
                <link rel="stylesheet" type="text/scss" href="/l10n_de/static/src/scss/report_din5008.scss"/>
            </xpath>
        </template>

        <!-- New report layout for din5008 format -->
        <template id="external_layout_din5008">
            <div>
                <div t-attf-class="header din_page o_company_#{company.id}_layout">
                        <table class="company_header" t-att-style="'height: %dmm;' % (din_header_spacing or 27)">
                            <tr>
                                <td><h3 class="mt0" t-field="company.report_header"/></td>
                                <td><img t-if="company.logo" t-att-src="image_data_uri(company.logo)" t-att-style="'max-height: %dmm;' % (din_header_spacing or 27)"/></td>
                            </tr>
                        </table>
                </div>

                <div t-attf-class="din_page invoice_note article o_company_#{company.id}_layout" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id">
                    <table>
                        <tr>
                            <td>
                                <div class="address">
                                    <t t-if="company.name">
                                        <span t-field="company.name"/> <span>|</span>
                                    </t>
                                    <t t-if="company.street">
                                        <span t-field="company.street"/> <span>|</span>
                                    </t>
                                    <t t-if="company.street2">
                                        <span t-field="company.street2"/> <span>|</span>
                                    </t>
                                    <t t-if="company.zip">
                                        <span t-field="company.zip"/>
                                    </t>
                                    <t t-if="company.city">
                                        <span t-field="company.city"/>
                                    </t>
                                    <hr class="company_invoice_line" />
                                    <div t-if="address">
                                        <t t-raw="address"/>
                                    </div>
                                    <div t-else="fallback_address">
                                        <t t-raw="fallback_address"
                                           t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}' />
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="information_block" t-if="o">
                                    <table t-if="o._name == 'account.move'">
                                        <tr><td>Invoice No.</td><td><span t-field="o.name"/></td></tr>
                                        <tr><td>Invoice Date</td><td><span t-field="o.invoice_date"/></td></tr>
                                        <tr><td>Due Date</td><td><span t-field="o.invoice_date_due"/></td></tr>
                                        <tr t-if="o.invoice_origin"><td>Source</td><td><span t-field="o.invoice_origin"/></td></tr>
                                        <tr t-if="o.ref"><td>Customer Reference</td><td><span t-field="o.ref"/></td></tr>
                                    </table>
                                    <table t-elif="o._name == 'sale.order'">
                                        <t t-if="o.state in ('draft', 'sent')">
                                            <tr><td>Quotation No.</td><td><span t-field="o.name"/></td></tr>
                                            <tr><td>Quotation Date</td><td><span t-field="o.date_order" t-options='{"widget": "date"}'/></td></tr>
                                            <tr><td>Expiration</td><td><span t-field="o.validity_date"/></td></tr>
                                        </t>
                                        <t t-else="">
                                            <tr><td>Order No.</td><td><span t-field="o.name"/></td></tr>
                                            <tr><td>Order Date</td><td><span t-field="o.date_order" t-options='{"widget": "date"}'/></td></tr>
                                        </t>
                                        <tr t-if="o.client_order_ref"><td>Customer Reference</td><td><span t-field="o.client_order_ref"/></td></tr>
                                        <tr t-if="o.user_id"><td>Salesperson</td><td><span t-field="o.user_id"/></td></tr>
                                    </table>
                                </div>
                            </td>
                        </tr>
                        <tr t-if="o and o._name == 'sale.order'">
                            <td>
                                <div class="shipping_address">
                                    <strong t-if="doc.partner_shipping_id == doc.partner_invoice_id">Invoicing and Shipping Address:</strong>
                                    <strong t-if="doc.partner_shipping_id != doc.partner_invoice_id">Shipping Address:</strong>
                                    <div t-field="doc.partner_shipping_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                                </div>
                            </td>
                            <td t-if="doc.partner_shipping_id != doc.partner_invoice_id">
                                <div class="invoice_address">
                                    <strong>Invoicing Address:</strong>
                                    <div t-field="doc.partner_invoice_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                                </div>
                            </td>
                        </tr>
                    </table>
                    <h2 t-if="not o">
                        <span>Invoice</span>
                    </h2>
                    <h2 t-elif="o._name == 'account.move'">
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</span>
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                        <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                        <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                        <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                    </h2>
                    <h2 t-elif="o._name == 'sale.order'">
                        <span t-if="o.state in ('draft', 'sent')">Quotation</span>
                        <span t-else="">Sales Order</span>
                    </h2>
                    <t t-raw="0"/>
                </div>

                <div t-attf-class="din_page footer o_company_#{company.id}_layout">
                    <div class="text-right page_number">
                        <div class="text-muted">
                            Page:
                            <span class="page"/>
                            of
                            <span class="topage"/>
                        </div>
                    </div>
                    <div class="company_details">
                        <table>
                            <tr>
                                <td>
                                    <ul class="list-inline">
                                        <li t-if="company.name"><span t-field="company.name"/></li>
                                        <li t-if="company.street"><span t-field="company.street"/></li>
                                        <li t-if="company.street2"><span t-field="company.street2"/></li>
                                        <li><span t-if="company.zip" t-field="company.zip"/> <span t-if="company.city" t-field="company.city"/></li>
                                        <li t-if="company.country_id"><span t-field="company.country_id.name"/></li>
                                    </ul>
                                </td>
                                <td>
                                    <ul class="list-inline">
                                        <li t-if="company.phone"><span t-field="company.phone"/></li>
                                        <li t-if="company.email"><span t-field="company.email"/></li>
                                        <li t-if="company.website"><span t-field="company.website"/></li>
                                    </ul>
                                </td>
                                <td>
                                    <ul class="list-inline">
                                        <li t-if="company.vat"><t t-esc="company.country_id.vat_label or 'Tax ID'"/>: <span t-field="company.vat"/></li>
                                        <li>HRB Nr: <span t-field="company.company_registry"/></li>
                                        <div t-field="company.report_footer"/>
                                    </ul>
                                </td>
                                <td>
                                    <ul class="list-inline" t-if="company.bank_ids">
                                        <li><span t-field="company.bank_ids[0].bank_id.name"/></li>
                                        <li>IBAN: <span t-field="company.bank_ids[0].acc_number"/></li>
                                        <li>BIC: <span t-field="company.bank_ids[0].bank_id.bic"/></li>
                                    </ul>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </template>

        <template id="din5008_css" inherit_id="web.styles_company_report">
            <xpath expr="//t[@t-elif]" position="before">
                <t t-elif="layout == 'l10n_de.external_layout_din5008'">
                    &amp;.din_page {
                        &amp;.header {
                            .company_header {
                                .name_container {
                                    color: <t t-esc='primary'/>;
                                }
                            }
                        }
                        &amp;.invoice_note {
                            td {
                                .address {
                                    > span {
                                        color: <t t-esc='secondary'/>;
                                    }
                                }
                            }
                            h2 {
                                color: <t t-esc='primary'/>;
                            }
                            .page {
                                [name=invoice_line_table] {
                                    th {
                                        color: <t t-esc='secondary'/>;
                                    }
                                }
                            }
                        }
                    }
                </t>
            </xpath>
        </template>
    </data>
</odoo>
