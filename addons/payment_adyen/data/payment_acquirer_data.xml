<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="account_payment_method_adyen" model="account.payment.method">
            <field name="name">Adyen</field>
            <field name="method_type" ref="payment.account_payment_method_type_electronic_in"/>
            <field name="state">deactivated</field>
        </record>
        <record id="payment.payment_acquirer_adyen" model="payment.acquirer">
            <field name="name">Adyen</field>
            <field name="image_128" type="base64" file="payment_adyen/static/src/img/adyen_icon.png"/>
