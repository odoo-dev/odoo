<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!-- Snippet -->
<template id="s_blog_posts" name="Dynamic Blog Posts">
    <t t-call="website.s_dynamic_snippet_template">
        <t t-set="snippet_name" t-value="'s_blog_posts s_dynamic_snippet_blog_posts s_blog_posts_big_picture s_blog_posts_effect_marley'"/>
    </t>
</template>

<!-- Load-time templates (rendered in JS on page load) -->
<!-- List layout -->
<template id="dynamic_filter_template_blog_posts_list" name="List layout">
    <div t-foreach="records" t-as="p" class="d-flex col-12 mt-3 s_blog_posts_post">
        <t t-set="record" t-value="p.get('_record')"/>
        <a class="s_blog_posts_post_cover flex-grow-0 flex-shrink-0 align-self-baseline position-relative" t-att-href="p.get('call_to_action_url')" t-att-title="'Read' + p.get('name')">
            <t t-if="'cover_properties_128' in record" t-call="website.record_cover">
                <t t-set="_record" t-value="record"/>
                <t t-set="_cp" t-value="json.loads(record.cover_properties_128)"/>
                <t t-set="additionnal_classes" t-value="'w-100 h-100 bg-200 position-absolute'"/>
            </t>
        </a>
        <div class="pl-2">
            <a class="" t-att-title="'Read' + p.get('name')" t-att-href="p.get('call_to_action_url')">
                <div class="s_blog_posts_post_title mb-1" t-raw="p.get('name')"/>
            </a>
            <div class="s_blog_posts_post_subtitle mb-1 d-none d-sm-block" t-raw="p.get('subtitle')"/>
        </div>
    </div>
</template>
<!-- Big picture layout -->
<template id="dynamic_filter_template_blog_posts_big_picture" name="Big picture layout">
    <figure t-foreach="records" t-as="p" class="col-md-6 col-lg-4 my-3 s_blog_posts_post">
        <t t-set="record" t-value="p.get('_record')"/>
        <a class="s_blog_posts_post_cover position-relative d-flex flex-column shadow-sm overflow-hidden rounded text-decoration-none" t-att-href="p.get('call_to_action_url')">
            <t t-if="'cover_properties_512' in record" t-call="website.record_cover">
                <t t-set="_record" t-value="record"/>
                <t t-set="_cp" t-value="json.loads(record.cover_properties_512)"/>
                <t t-set="use_filters" t-value="True"/>
                <t t-set="additionnal_classes" t-value="'h-100 w-100 bg-600 position-absolute'"/>
            </t>

            <figcaption class="text-center w-100 h-100 px-3 d-flex flex-column flex-grow-1">
                <div class="s_blog_posts_post_title text-white" t-raw="p.get('name')"/>
                <div class="s_blog_posts_post_subtitle text-white" t-raw="p.get('subtitle')"/>
            </figcaption>
        </a>
    </figure>
</template>
<!-- Horizontal layout -->
<template id="dynamic_filter_template_blog_posts_horizontal" name="Horizontal layout">
    <figure t-foreach="records" t-as="p" class="post s_blog_posts_post col-md-6 col-lg-4">
        <t t-set="record" t-value="p.get('_record')"/>
        <figcaption>
            <h4 class="mb0"><a t-att-href="p.get('call_to_action_url')"><t t-raw="p.get('name')"/></a></h4>
            <h5 class="mt0 mb4" t-if="record and 'write_date' in record" t-field="record.write_date" t-options='{"format": "dd/MM"}' />
        </figcaption>
        <a t-att-href="p.get('call_to_action_url')">
            <t t-if="'cover_properties_512' in record" t-call="website.record_cover">
                <t t-set="_record" t-value="record"/>
                <t t-set="_cp" t-value="json.loads(record.cover_properties_512)"/>
                <t t-set="additionnal_classes" t-value="'loading_container thumb'"/>
            </t>
        </a>
    </figure>
</template>
<!-- Card layout -->
<template id="dynamic_filter_template_blog_posts_card" name="Card layout">
    <div t-foreach="records" t-as="p" class="col-md-6 col-lg-4 s_blog_posts_post pb32">
        <t t-set="record" t-value="p.get('_record')"/>
        <div class="card">
            <a class="s_blog_posts_post_cover" t-att-href="p.get('call_to_action_url')">
                <t t-if="'cover_properties_256' in record" t-call="website.record_cover">
                    <t t-set="_record" t-value="record"/>
                    <t t-set="_cp" t-value="json.loads(record.cover_properties_256)"/>
                    <t t-set="additionnal_classes" t-value="'loading_container thumb'"/>
                </t>
            </a>
            <div class="card-body">
                <a t-att-href="p.get('call_to_action_url')"><h4 class="mb-0"><t t-raw="p.get('name')"/></h4></a>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <span class="text-muted mb-0" t-if="record and 'write_date' in record" t-field="record.write_date" t-options='{"format": "MMM d, yyyy"}' />
                <span class="text-muted mb-0">In <a class="font-weight-bold" t-raw="p.get('blog_name')" t-att-href="p.get('blog_url')" /></span>
            </div>
        </div>
    </div>
</template>

<!-- Options -->
<template id="s_blog_posts_options" inherit_id="website.snippet_options">
    <xpath expr="." position="inside">
        <t t-call="website_blog.s_dynamic_snippet_options_template">
            <t t-set="snippet_name" t-value="'dynamic_snippet_blog_posts'"/>
            <t t-set="snippet_selector" t-value="'.s_dynamic_snippet_blog_posts'"/>
            <we-select string="Blog" data-no-preview="true" data-name="blog_opt" data-attribute-name="filterByBlogId">
                <we-button data-select-data-attribute="-1">All blogs</we-button>
                <!-- the blog list will be generated in js -->
            </we-select>
            <we-select string="Posts" data-no-preview="true" data-attribute-name="order" class="o_we_inline">
                <we-button data-select-data-attribute="published_date desc">Latest</we-button>
                <we-button data-select-data-attribute="visits desc">Most viewed</we-button>
            </we-select>
        </t>
    </xpath>
    <xpath expr="//div[@data-js='layout_column']" position="attributes">
        <attribute name="data-exclude" add=".s_blog_posts, .s_blog_posts_big_picture" separator=","/>
    </xpath>
</template>

<template id="s_dynamic_snippet_options_template" inherit_id="website.s_dynamic_snippet_options_template">
    <xpath expr="//we-select[@data-name='template_opt']" position="after">
        <we-select string="⌙ Hover effect" data-no-widget-refresh="true" data-name="hover_effect_opt" xxdata-dependencies="big_picture_opt" class="o_we_inline">
            <we-button data-select-class="">None</we-button>
            <we-button data-select-class="s_blog_posts_effect_marley">Marley</we-button>
            <we-button data-select-class="s_blog_posts_effect_dexter">Dexter</we-button>
            <we-button data-select-class="s_blog_posts_effect_chico">Silly-Chico</we-button>
        </we-select>
    </xpath>
</template>

<!-- Assets -->
<template id="assets_snippet_s_blog_posts_css_000" inherit_id="website.assets_frontend">
    <xpath expr="//link[last()]" position="after">
        <link rel="stylesheet" type="text/scss" href="/website_blog/static/src/snippets/s_blog_posts/000.scss"/>
    </xpath>
</template>

<template id="assets_snippet_s_blog_posts_js_000" inherit_id="website.assets_frontend">
    <xpath expr="//script[last()]" position="after">
        <script type="text/javascript" src="/website_blog/static/src/snippets/s_blog_posts/000.js"/>
    </xpath>
</template>

</odoo>
