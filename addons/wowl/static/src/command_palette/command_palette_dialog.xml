<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="wowl.CommandPaletteDialog" owl="1">
    <Dialog title="props.title" renderFooter="false">
      <input type="text" t-att-placeholder="props.placeholder" />
      <t t-foreach="props.categories" t-as="category">
        <ul>
          <t t-foreach="category.items" t-as="item">
            <h6 t-if="item_first and category.label" t-esc="category.label" />
            <li>
              <t t-esc="item.name" />
              :
              <kbd t-esc="item.hotkey" />
            </li>
          </t>
        </ul>
        <hr t-if="!category_last" />
      </t>
    </Dialog>
  </t>

</templates>
